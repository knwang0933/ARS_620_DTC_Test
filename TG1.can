/// <0x10服务>
testcase UDS_0x10_NRC_12()
{
  byte res[5];
  testCaseTitle("10服务","UDS_0x10_NRC_12");
  res[0] = 0x12;
  TxSVC10(phy_add_id,0x02,0x10,0x00);
  RXResponseCodeJudge(res,phy_add_id,0x10);
