/// <0x31服务>
testcase UDS_0x31_NRC_13()//Communication Test
{
  byte res[5]; 
  struct DID_st did_ED05;
  byte byt_ED05[4]={0x70,0x50,0x18,0x49};//IP地址
  did_ED05.DID=0xED05;
  did_ED05.dlc=4;
  ByteToFill(byt_ED05, did_ED05.Res_Data,did_ED05.dlc);
  testCaseTitle("31服务","UDS_0x31_NRC_13");
  TxSVC10(phy_add_id,0x02,0x10,0x03);
  testWaitForTimeout(200);
  TxSVC31_Abnormal(phy_add_id,0x02,0x31,0x01);
  res[0]=0x13;
  did_ED05.Res_Data[0]=0xED;
  did_ED05.Res_Data[1]=0xFF;
  did_ED05.Res_Data[2]=0xFF;
  RXResponse31Judge(res,phy_add_id,did_ED05.DID,0x03,did_ED05.Res_Data,0x31);
  testWaitForTimeout(500);
}

